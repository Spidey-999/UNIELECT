// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phoneNumber  String?  @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ballots      Ballot[]

  @@map("users")
}

model Election {
  id          String   @id @default(cuid())
  title       String
  description String
  startsAt    DateTime
  endsAt      DateTime
  method      String   @default("FPTP") // First-Past-The-Post
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  races            Race[]         @relation("ElectionRaces")
  eligibleStudents EligibleStudent[]
  tokens           Token[]
  ballots          Ballot[]
  auditLogs        AuditLog[]
  verifiedVoters   VerifiedVoter[]
  smsVerifications SmsVerification[]

  @@index([startsAt])
  @@index([endsAt])
  @@index([createdAt])
  @@map("elections")
}

model VerifiedVoter {
  id         String   @id @default(cuid())
  electionId String
  externalId String
  phoneNumber String
  verifiedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  tokens   Token[]
  ballots  Ballot[]

  @@unique([electionId, externalId])
  @@unique([electionId, phoneNumber])
  @@index([electionId])
  @@map("verified_voters")
}

model SmsVerification {
  id          String   @id @default(cuid())
  electionId  String
  externalId  String
  phoneNumber String
  codeHash    String
  expiresAt   DateTime
  verifiedAt  DateTime?
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([electionId, externalId])
  @@index([electionId, phoneNumber])
  @@index([expiresAt])
  @@map("sms_verifications")
}

model Race {
  id          String @id @default(cuid())
  electionId  String
  title       String
  maxChoices  Int    @default(1)
  description String?

  election   Election   @relation("ElectionRaces", fields: [electionId], references: [id], onDelete: Cascade)
  candidates Candidate[]
  choices    BallotChoice[]

  @@index([electionId])
  @@map("races")
}

model Candidate {
  id       String @id @default(cuid())
  raceId   String
  name     String
  bio      String?
  photoUrl String?

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)
  choices BallotChoice[]

  @@map("candidates")
}

model EligibleStudent {
  id          String @id @default(cuid())
  electionId  String
  externalId  String // Student ID or email from CSV
  issued      Boolean @default(false)

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  tokens   Token[]

  @@unique([electionId, externalId])
  @@map("eligible_students")
}

model Token {
  id                String    @id @default(cuid())
  electionId        String
  value             String    @unique
  issuedAt          DateTime  @default(now())
  usedAt            DateTime?
  expiresAt         DateTime?
  email             String?   // Store email for direct token access
  eligibleStudentId String?
  verifiedVoterId   String?

  election        Election        @relation(fields: [electionId], references: [id], onDelete: Cascade)
  eligibleStudent EligibleStudent? @relation(fields: [eligibleStudentId], references: [id], onDelete: SetNull)
  verifiedVoter   VerifiedVoter?  @relation(fields: [verifiedVoterId], references: [id], onDelete: SetNull)

  @@index([value])
  @@index([electionId])
  @@index([usedAt])
  @@index([expiresAt])
  @@index([verifiedVoterId])
  @@index([email])
  @@map("tokens")
}

model Ballot {
  id         String   @id @default(cuid())
  electionId String
  userId     String?  // Link to registered users
  verifiedVoterId String?
  castAt     DateTime @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  verifiedVoter VerifiedVoter? @relation(fields: [verifiedVoterId], references: [id], onDelete: SetNull)
  choices  BallotChoice[]

  @@index([electionId])
  @@index([userId])
  @@index([verifiedVoterId])
  @@index([castAt])
  @@unique([electionId, verifiedVoterId])
  @@map("ballots")
}

model BallotChoice {
  id         String @id @default(cuid())
  ballotId   String
  raceId     String
  candidateId String
  rank       Int?   // For future Ranked Choice Voting

  ballot   Ballot   @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  race     Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([ballotId, raceId, candidateId])
  @@map("ballot_choices")
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String   // Admin email or system
  action    String   // CREATE_ELECTION, GENERATE_TOKENS, etc.
  metadata  Json?    // Additional context
  createdAt DateTime @default(now())
  electionId String?

  election Election? @relation(fields: [electionId], references: [id])

  @@map("audit_logs")
}
